def manager_portal(store):
    if not manager_login():
        return
    print("\n==============")
    print("Add Products")
    print("==============")
    while True:
        name = input("Enter product name (or 'done' to finish): ")
        if name == 'done':
            break
        price = float(input("Enter product price: "))
        stock = int(input("Enter product stock quantity: "))
        store.add_product(name, price, stock)
    print("Returning to main menu...")
def customer_portal(store, cart):
    while True:
        print("\n==============")
        print("CUSTOMER PORTAL")
        print("==============")
        store.show_products()
        print("\nWhat would you like to do?")
        print("Type: add / remove / view / checkout / back")
        choice = input("Enter choice: ").lower()
        if choice == 'add':
            store.show_products()
            if len(store.products) == 0:
                continue
            name = input("\nEnter product name: ")
            product_index = store.find_product(name)
            if product_index == -1:
                print(f"X Product '{name}' not found.")
                continue
            quantity = int(input("Enter quantity: "))
            stock = store.products[product_index].stock
            if quantity > stock:
                print(f"X Not enough stock! Only {stock} available.")
                continue
            cart.add_to_cart(store.products[product_index], quantity)
            store.products[product_index].stock -= quantity
        elif choice == 'remove':
            name = input("\nEnter product name to remove: ")
            cart.remove_from_cart(name)
        elif choice == 'view':
            cart.view_cart()
        
        elif choice == 'checkout':
            if cart.checkout():
                cart.clear()
                break
        elif choice == 'back':
            print("Returning to main menu...")
            break
        else:
            print("X Invalid choice. Please type: add, remove, view, checkout, or back")
