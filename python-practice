class Product:
    def __init__(self, name, price, stock):
        self.name = name
        self.price = price
        self.stock = stock
class Store:
    def __init__(self):
        self.products = []
    def add_product(self, name, price, stock):
        self.products.append(Product(name, price, stock))
        print(f"Product added: {name} - ${price:.2f} (Stock: {stock})\n")
    def find_product(self, name):
        for i in range(len(self.products)):
            if self.products[i].name.lower() == name.lower():
                return i
        return -1
    def show_products(self):
        print("\n--- Available products:")
        if len(self.products) == 0:
            print("No products available.")
            return
        for i in range(len(self.products)):
            print(f"[{i+1}] {self.products[i].name} - ${self.products[i].price:.2f} (Stock: {self.products[i].stock})")
class CartItem:
    def __init__(self, product, quantity):
        self.product = product
        self.quantity = quantity
class Cart:
    def __init__(self):
        self.items = []
    def add_to_cart(self, product, quantity):
        for i in range(len(self.items)):
            if self.items[i].product.name.lower() == product.name.lower():
                self.items[i].quantity += quantity
                print(f"Added {quantity} x {product.name} to cart.")
                return
        self.items.append(CartItem(product, quantity))
        print(f"Added {quantity} x {product.name} to cart.")
    def remove_from_cart(self, name):
        if len(self.items) == 0:
            print("X Your cart is empty.")
            return
        for i in range(len(self.items)):
            if self.items[i].product.name.lower() == name.lower():
                del self.items[i]
                print(f"Removed {name} from cart.")
                return
        print(f"X '{name}' not found in cart.")
    def view_cart(self):
        if len(self.items) == 0:
            print("\nX Your cart is empty.")
            return
        print("\n--- Your Cart ---")
        total = 0
        for i in range(len(self.items)):
            item_total = self.items[i].product.price * self.items[i].quantity
            total = total + item_total
            print(f"- {self.items[i].product.name} x{self.items[i].quantity} - ${item_total:.2f}")
        print(f"Total: ${total:.2f}")
    def checkout(self):
        if len(self.items) == 0:
            print("\nX Your cart is empty. Nothing to checkout.")
            return False
        print("\n==============")
        print("Final checkout:")
        print("==============")
        total = 0
        for i in range(len(self.items)):
            item_total = self.items[i].product.price * self.items[i].quantity
            total = total + item_total
            print(f"- {self.items[i].product.name} x{self.items[i].quantity} - ${item_total:.2f}")
        print(f"Total amount due: ${total:.2f}")
        print("Thank you for shopping with us!\n")
        return True
    def clear(self):
        self.items = []
